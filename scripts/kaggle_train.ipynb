   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# CascadeShield: Full Training Run (Kaggle)\n",
    "\n",
    "This notebook orchestrates the 700-scenario full training run of `CascadeNet`.\n",
    "It assumes you have uploaded the `cascade shield` repository as a Kaggle Dataset named `cascade-shield-data`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import os\n",
    "import shutil\n",
    "\n",
    "# 1. Sanity-check GPU is actually attached\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"[PASS] GPU attached: {torch.cuda.get_device_name(0)}\")\n",
    "else:\n",
    "    print(\"[FAIL] No GPU detected! Stop the run and toggle the P100/T4 accelerator setting.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 2. Setup paths and copy code to /kaggle/working/ so we can write checkpoints\n",
    "if os.path.exists('/kaggle/working/cascade_shield'):\n",
    "    shutil.rmtree('/kaggle/working/cascade_shield')\n",
    "\n",
    "shutil.copytree('/kaggle/input/cascade-shield-data', '/kaggle/working/cascade_shield')\n",
    "os.chdir('/kaggle/working/cascade_shield')\n",
    "print(\"Working directory set to:\", os.getcwd())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3. Verify path-detection logic and early trajectory (1-2 epochs)\n",
    "print(\"--- KICKOFF CHECK: Running 2 epochs to verify checkpoints ---\")\n",
    "!python models/train.py --epochs 2\n",
    "\n",
    "if os.path.exists('/kaggle/working/cascade_shield/checkpoints/checkpoint_latest.pth'):\n",
    "    print(\"\\n[PASS] checkpoint_latest.pth successfully landed in /kaggle/working/...\")\n",
    "else:\n",
    "    print(\"\\n[FAIL] Checkpoint not found where expected. Path detection logic failed!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4. Full unattended run\n",
    "print(\"\\n--- FULL TRAINING RUN ---\")\n",
    "!python models/train.py --epochs 100"
   ]
  }
 ],
